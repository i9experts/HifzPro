// prisma/schema.prisma
// HifzPro Complete Database Schema v2.0
// ═══════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  CAMPUS_ADMIN
  USTADH
  PARENT
  STUDENT
  EXAMINER
  DONOR
}

enum Program {
  HIFZ
  NAZRA
  TAJWEED
  GIRDAAN
}

enum StudentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  COMPLETED
  WITHDRAWN
}

enum Grade {
  EXCELLENT
  GOOD
  WEAK
  REPEAT
}

enum MistakeType {
  ATAK        // Hesitation
  TAJWEED     // Tajweed error
  LAHN_JALI   // Major error
  LAHN_KHAFI  // Minor error
}

enum LessonType {
  SABAQ       // New lesson
  SABQI       // Recent consolidation
  MANZIL      // Long-term revision
  GIRDAAN     // Revision cycle
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum AbsenceReason {
  ILLNESS
  TRAVEL
  FAMILY
  UNEXCUSED
  HOLIDAY
}

enum TestType {
  SABAQ_TEST
  SABQI_TEST
  PARA_TEST
  NUSS_TEST       // 15 Para test
  TARTEEB_TEST    // Random Ayah test
  FULL_QURAN_TEST // Final Dour test
  GIRDAAN_TEST
}

enum TestResult {
  PASS
  CONDITIONAL_PASS
  FAIL
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum MushaF {
  MADANI_15_LINE
  MADANI_13_LINE
  INDOPAK_16_LINE
}

// ─────────────────────────────────────────
// INSTITUTION & CAMPUS
// ─────────────────────────────────────────

model Institution {
  id          String   @id @default(cuid())
  name        String
  nameArabic  String?
  slug        String   @unique
  logo        String?
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String   @default("Pakistan")
  website     String?
  mushaf      MushaF   @default(MADANI_15_LINE)
  isActive     Boolean  @default(true)
  isOnboarded  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campuses      Campus[]
  users         User[]
  donors        Donor[]
  subscriptions Subscription[]

  @@map("institutions")
}

model Campus {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  nameArabic    String?
  address       String?
  city          String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  batches       Batch[]
  users         User[]
  students      Student[]
  feeStructures FeeStructure[]

  @@map("campuses")
}

// ─────────────────────────────────────────
// USERS (All roles in one table)
// ─────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  institutionId String?
  campusId      String?
  role          Role
  name          String
  nameArabic    String?
  email         String?  @unique
  phone         String?  @unique
  whatsapp      String?
  passwordHash  String?
  avatar        String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution         Institution? @relation(fields: [institutionId], references: [id])
  campus              Campus?      @relation(fields: [campusId], references: [id])
  ustadh              Ustadh?
  parent              Parent?
  otpTokens           OtpToken[]
  sessions            Session[]
  issuedSanads        Sanad[]      @relation("IssuedSanads")
  collectedFees       FeePayment[] @relation("FeeCollectedBy")
  grantedScholarships Scholarship[] @relation("ScholarshipGrantedBy")

  @@map("users")
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_tokens")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────
// USTADH
// ─────────────────────────────────────────

model Ustadh {
  id              String   @id @default(cuid())
  userId          String   @unique
  qualification   String?
  specialization  String?
  joinedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches         Batch[]
  lessonEntries   LessonEntry[]
  testRecords     TestRecord[]

  @@map("asatidha")
}

// ─────────────────────────────────────────
// BATCH / HALQA
// ─────────────────────────────────────────

model Batch {
  id          String   @id @default(cuid())
  campusId    String
  ustadhId    String?
  name        String
  program     Program
  sessionTime String?
  maxStudents Int      @default(20)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campus      Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  ustadh      Ustadh?  @relation(fields: [ustadhId], references: [id])
  students    Student[]
  attendance  AttendanceSession[]

  @@map("batches")
}

// ─────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────

model Student {
  id                String        @id @default(cuid())
  campusId          String
  batchId           String?
  enrollmentNumber  String?       @unique
  name              String
  nameArabic        String?
  dateOfBirth       DateTime?
  photo             String?
  program           Program
  status            StudentStatus @default(ACTIVE)
  enrolledAt        DateTime      @default(now())
  expectedKhatmAt   DateTime?
  actualKhatmAt     DateTime?

  startingJuz       Int?          @default(1)
  startingSurah     Int?
  startingAyah      Int?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  campus            Campus        @relation(fields: [campusId], references: [id])
  batch             Batch?        @relation(fields: [batchId], references: [id])
  guardians         Guardian[]
  lessonEntries     LessonEntry[]
  attendanceRecords AttendanceRecord[]
  testRecords       TestRecord[]
  manzilHealth      ManzilHealth[]
  progress          StudentProgress?
  sanads            Sanad[]
  scholarships      Scholarship[]
  feePayments       FeePayment[]
  mutashabihat      StudentMutashabihat[]

  @@map("students")
}

model Guardian {
  id             String   @id @default(cuid())
  studentId      String
  name           String
  relation       String
  cnic           String?
  phone          String
  whatsapp       String?
  email          String?
  isEmergency    Boolean  @default(false)
  receiveUpdates Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent         Parent?

  @@map("guardians")
}

model Parent {
  id          String   @id @default(cuid())
  userId      String   @unique
  guardianId  String?  @unique
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardian    Guardian? @relation(fields: [guardianId], references: [id])

  @@map("parents")
}

// ─────────────────────────────────────────
// LESSON ENTRY (Core of HifzPro)
// ─────────────────────────────────────────

model LessonEntry {
  id            String     @id @default(cuid())
  studentId     String
  ustadhId      String
  lessonType    LessonType
  date          DateTime   @default(now())

  juzFrom       Int?
  surahFrom     Int?
  ayahFrom      Int?
  pageFrom      Int?
  lineFrom      Int?

  juzTo         Int?
  surahTo       Int?
  ayahTo        Int?
  pageTo        Int?
  lineTo        Int?

  grade         Grade?
  durationMins  Int?
  mistakeCount  Int        @default(0)
  notes         String?
  voiceNoteUrl  String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  ustadh        Ustadh     @relation(fields: [ustadhId], references: [id])
  mistakes      Mistake[]

  @@map("lesson_entries")
}

model Mistake {
  id            String      @id @default(cuid())
  lessonEntryId String
  mistakeType   MistakeType
  surah         Int?
  ayah          Int?
  page          Int?
  description   String?
  createdAt     DateTime    @default(now())

  lessonEntry   LessonEntry @relation(fields: [lessonEntryId], references: [id], onDelete: Cascade)

  @@map("mistakes")
}

// ─────────────────────────────────────────
// MANZIL HEALTH (The Intelligence Layer)
// ─────────────────────────────────────────

model ManzilHealth {
  id           String   @id @default(cuid())
  studentId    String
  score        Float
  juzNumber    Int?
  calculatedAt DateTime @default(now())

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("manzil_health")
}

// ─────────────────────────────────────────
// STUDENT PROGRESS
// ─────────────────────────────────────────

model StudentProgress {
  id                  String   @id @default(cuid())
  studentId           String   @unique
  totalAyahsMemorized Int      @default(0)
  totalPagesMemorized Int      @default(0)
  totalJuzMemorized   Int      @default(0)
  currentJuz          Int      @default(1)
  currentSurah        Int?
  currentAyah         Int?
  currentPage         Int?
  percentComplete     Float    @default(0)
  projectedKhatmDate  DateTime?
  avgLinesPerDay      Float    @default(0)
  updatedAt           DateTime @updatedAt

  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_progress")
}

// ─────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────

model AttendanceSession {
  id          String   @id @default(cuid())
  batchId     String
  date        DateTime
  sessionTime String?
  takenById   String?
  createdAt   DateTime @default(now())

  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  records     AttendanceRecord[]

  @@unique([batchId, date, sessionTime])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                  String           @id @default(cuid())
  attendanceSessionId String
  studentId           String
  status              AttendanceStatus @default(PRESENT)
  absenceReason       AbsenceReason?
  returnDate          DateTime?
  notes               String?
  createdAt           DateTime         @default(now())

  session             AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([attendanceSessionId, studentId])
  @@map("attendance_records")
}

// ─────────────────────────────────────────
// TESTS & ASSESSMENTS
// ─────────────────────────────────────────

model TestRecord {
  id            String     @id @default(cuid())
  studentId     String
  examinerId    String
  testType      TestType
  date          DateTime   @default(now())

  juzFrom       Int?
  juzTo         Int?
  surahFrom     Int?
  surahTo       Int?

  result        TestResult?
  score         Float?
  mistakeCount  Int        @default(0)
  notes         String?
  conditions    String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examiner      Ustadh     @relation(fields: [examinerId], references: [id])

  @@map("test_records")
}

// ─────────────────────────────────────────
// SANAD & CERTIFICATION
// ─────────────────────────────────────────

model Sanad {
  id          String   @id @default(cuid())
  studentId   String
  issuedById  String?
  sanadNumber String   @unique
  program     Program
  issuedAt    DateTime @default(now())
  silsila     String?
  qrCode      String?
  pdfUrl      String?
  isVerified  Boolean  @default(true)

  student     Student  @relation(fields: [studentId], references: [id])
  issuedBy    User?    @relation("IssuedSanads", fields: [issuedById], references: [id])

  @@map("sanads")
}

// ─────────────────────────────────────────
// NOTIFICATIONS (WhatsApp / Email)
// ─────────────────────────────────────────

model Notification {
  id          String              @id @default(cuid())
  recipientId String
  channel     NotificationChannel
  type        String
  title       String?
  body        String
  metadata    Json?
  status      NotificationStatus  @default(PENDING)
  sentAt      DateTime?
  readAt      DateTime?
  error       String?
  createdAt   DateTime            @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────
// FEES & FINANCE
// ─────────────────────────────────────────

model FeeStructure {
  id          String       @id @default(cuid())
  campusId    String
  name        String
  program     String?
  amount      Float
  frequency   String       @default("MONTHLY")
  feeType     String       @default("TUITION")
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  campus      Campus       @relation(fields: [campusId], references: [id])
  payments    FeePayment[]

  @@map("fee_structures")
}

model FeePayment {
  id             String        @id @default(cuid())
  studentId      String
  feeStructureId String?
  amount         Float
  paidAmount     Float         @default(0)
  discountAmount Float         @default(0)
  month          Int
  year           Int
  status         String        @default("PENDING")
  paymentDate    DateTime?
  paymentMethod  String?
  receiptNumber  String        @unique
  notes          String?
  collectedById  String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student        Student       @relation(fields: [studentId], references: [id])
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  collectedBy    User          @relation("FeeCollectedBy", fields: [collectedById], references: [id])

  @@map("fee_payments")
}

// ─────────────────────────────────────────
// DONORS & SCHOLARSHIPS
// ─────────────────────────────────────────

model Donor {
  id            String    @id @default(cuid())
  institutionId String
  name          String
  email         String?
  phone         String?
  isAnonymous   Boolean   @default(false)
  passwordHash  String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  institution   Institution   @relation(fields: [institutionId], references: [id])
  scholarships  Scholarship[]

  @@map("donors")
}

model Scholarship {
  id          String    @id @default(cuid())
  studentId   String
  donorId     String?
  name        String    @default("Scholarship")
  type        String    @default("FULL")
  percentage  Float?
  fixedAmount Float?
  reason      String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  grantedById String
  createdAt   DateTime  @default(now())

  student     Student   @relation(fields: [studentId], references: [id])
  donor       Donor?    @relation(fields: [donorId], references: [id])
  grantedBy   User      @relation("ScholarshipGrantedBy", fields: [grantedById], references: [id])

  @@map("scholarships")
}

// ─────────────────────────────────────────
// QURAN REFERENCE DATA
// ─────────────────────────────────────────

model Surah {
  id          Int    @id
  nameArabic  String
  nameEnglish String
  nameUrdu    String?
  juzNumber   Int
  ayahCount   Int
  pageStart   Int?
  pageEnd     Int?
  isRukuCount Int?

  @@map("surahs")
}

model MutashabihatPair {
  id          String   @id @default(cuid())
  campusId    String?
  surah1      Int
  ayah1       Int
  juz1        Int
  text1       String
  surah2      Int
  ayah2       Int
  juz2        Int
  text2       String
  category    String   @default("BEGINNING")
  difficulty  Int      @default(3)
  difference  String?
  notes       String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  confusions  StudentMutashabihat[]

  @@map("mutashabihat_pairs")
}

model StudentMutashabihat {
  id                 String    @id @default(cuid())
  studentId          String
  pairId             String?
  correctSurah       Int
  correctAyah        Int
  correctJuz         Int
  correctText        String?
  confusedWithSurah  Int
  confusedWithAyah   Int
  confusedWithJuz    Int
  confusedText       String?
  confusionCount     Int       @default(1)
  firstConfusedAt    DateTime  @default(now())
  lastConfusedAt     DateTime  @default(now())
  resolvedAt         DateTime?
  isResolved         Boolean   @default(false)
  priority           Int       @default(50)
  lessonEntryId      String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  student            Student             @relation(fields: [studentId], references: [id])
  pair               MutashabihatPair?   @relation(fields: [pairId], references: [id])

  @@map("student_mutashabihat")
}

model Subscription {
  id            String    @id @default(cuid())
  institutionId String    @unique
  plan          String    @default("TRIAL")
  status        String    @default("TRIAL")
  amount        Float     @default(0)
  currency      String    @default("PKR")
  billingCycle  String    @default("MONTHLY")
  startDate     DateTime  @default(now())
  endDate       DateTime?
  trialEndsAt   DateTime?
  cancelledAt   DateTime?
  lastPaymentAt DateTime?
  nextBillingAt DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])

  @@map("subscriptions")
}
